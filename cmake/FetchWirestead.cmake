include(FetchContent)

if(DEFINED UNILINK_BENCH_UNILINK_SOURCE_DIR AND NOT DEFINED WIRESTEAD_BENCH_SOURCE_DIR)
  set(WIRESTEAD_BENCH_SOURCE_DIR
      "${UNILINK_BENCH_UNILINK_SOURCE_DIR}"
      CACHE PATH "Optional local Wirestead source directory for benchmark development" FORCE)
endif()
if(DEFINED UNILINK_BENCH_UNILINK_GIT_REPOSITORY AND NOT DEFINED WIRESTEAD_BENCH_GIT_REPOSITORY)
  set(WIRESTEAD_BENCH_GIT_REPOSITORY
      "${UNILINK_BENCH_UNILINK_GIT_REPOSITORY}"
      CACHE STRING "Wirestead Git repository used by FetchContent" FORCE)
endif()
if(DEFINED UNILINK_BENCH_UNILINK_GIT_TAG AND NOT DEFINED WIRESTEAD_BENCH_GIT_TAG)
  set(WIRESTEAD_BENCH_GIT_TAG
      "${UNILINK_BENCH_UNILINK_GIT_TAG}"
      CACHE STRING "Wirestead Git tag, branch, or commit used by FetchContent" FORCE)
endif()

set(WIRESTEAD_BENCH_SOURCE_DIR
    ""
    CACHE PATH "Optional local Wirestead source directory for benchmark development")
set(WIRESTEAD_BENCH_GIT_REPOSITORY
    "https://github.com/wirestead/wirestead.git"
    CACHE STRING "Wirestead Git repository used by FetchContent")
set(WIRESTEAD_BENCH_GIT_TAG
    "main"
    CACHE STRING "Wirestead Git tag, branch, or commit used by FetchContent")

set(WIRESTEAD_BUILD_EXAMPLES OFF CACHE BOOL "" FORCE)
set(WIRESTEAD_BUILD_TESTS OFF CACHE BOOL "" FORCE)
set(WIRESTEAD_BUILD_DOCS OFF CACHE BOOL "" FORCE)
set(WIRESTEAD_BUILD_SHARED ON CACHE BOOL "" FORCE)
set(WIRESTEAD_BUILD_STATIC OFF CACHE BOOL "" FORCE)
set(WIRESTEAD_ENABLE_PERFORMANCE_TESTS OFF CACHE BOOL "" FORCE)
set(WIRESTEAD_ENABLE_INSTALL OFF CACHE BOOL "" FORCE)

set(UNILINK_BUILD_EXAMPLES OFF CACHE BOOL "" FORCE)
set(UNILINK_BUILD_TESTS OFF CACHE BOOL "" FORCE)
set(UNILINK_BUILD_DOCS OFF CACHE BOOL "" FORCE)
set(UNILINK_BUILD_SHARED ON CACHE BOOL "" FORCE)
set(UNILINK_BUILD_STATIC OFF CACHE BOOL "" FORCE)
set(UNILINK_ENABLE_PERFORMANCE_TESTS OFF CACHE BOOL "" FORCE)
set(UNILINK_ENABLE_INSTALL OFF CACHE BOOL "" FORCE)
set(BUILD_PYTHON_BINDINGS OFF CACHE BOOL "" FORCE)

if(WIRESTEAD_BENCH_SOURCE_DIR)
  FetchContent_Declare(wirestead SOURCE_DIR ${WIRESTEAD_BENCH_SOURCE_DIR})
else()
  FetchContent_Declare(
    wirestead
    GIT_REPOSITORY ${WIRESTEAD_BENCH_GIT_REPOSITORY}
    GIT_TAG ${WIRESTEAD_BENCH_GIT_TAG}
  )
endif()

FetchContent_MakeAvailable(wirestead)
